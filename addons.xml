<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="plugin.video.streamcontinuum" name="StreamContinuum" version="1.1.4" provider-name="LawkCornieur">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
        <import addon="inputstream.adaptive" version="2.6.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Simple stream addon with Trakt.tv and Webshare integration.</summary>
        <summary lang="cs_CZ">Jednoduchý stream doplněk s integrací Trakt.tv a Webshare.</summary>
        <description lang="en_GB">StreamContinuum allows you to browse and play content from Webshare.cz with full Trakt.tv synchronization and local history.</description>
        <description lang="cs_CZ">StreamContinuum umožňuje prohlížet a přehrávat obsah z Webshare.cz s plnou synchronizací Trakt.tv a lokální historií.</description>
        <disclaimer lang="en_GB">This addon does not host any content. It is a tool to access third-party services.</disclaimer>
        <disclaimer lang="cs_CZ">Tento doplněk nehostuje žádný obsah. Je to pouze nástroj pro přístup ke službám třetích stran.</disclaimer>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="repository.streamcontinuum" name="StreamContinuum Repository" version="1.0.9" provider-name="LawkCornieur">
    <extension point="xbmc.addon.repository" name="StreamContinuum Repository">
        <dir>
            <info compressed="false">https://lawkcornieur.github.io/StreamContinuum/addons.xml</info>
            <checksum>https://lawkcornieur.github.io/StreamContinuum/addons.xml.md5</checksum>
            <datadir zip="true">https://lawkcornieur.github.io/StreamContinuum/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">StreamContinuum Repository</summary>
        <summary lang="cs_CZ">Repozitář StreamContinuum</summary>
        <description lang="en_GB">Repository for StreamContinuum Kodi Addon. Provides automatic updates.</description>
        <description lang="cs_CZ">Repozitář pro Kodi doplněk StreamContinuum. Poskytuje automatické aktualizace.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
</addons>

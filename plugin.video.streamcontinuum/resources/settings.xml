<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
    <section id="main">
        <category id="trakt" label="30000">
            <group id="trakt_account" label="30001">
                <setting id="trakt_token" type="string" label="30002" default="" visible="false"/>
